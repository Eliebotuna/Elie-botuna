# Gmail — variables lues par server/index.js (pas exposées au navigateur)
GMAIL_USER=votrecompte@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
CONTACT_TO_EMAIL=votrecompte@gmail.com

# Si la connexion échoue encore : essaie le port 587 (décommente la ligne)
# GMAIL_SMTP_PORT=587

# Test SMTP sans lancer le site : npm run verify-mail

# Production : URL publique du serveur Node (sans slash final)
# REACT_APP_CONTACT_API_URL=https://api.votredomaine.com

# En développement : laisser REACT_APP_CONTACT_API_URL vide + lancer npm run dev (CRA proxy → port 5001)
# Si besoin : PORT=5002 dans .env côté serveur + "proxy": "http://localhost:5002" dans package.json
