# --- Gmail (côté serveur Node UNIQUEMENT — ne jamais préfixer par REACT_APP_) ---
# Compte Gmail + mot de passe d’application (Google → Sécurité → Mots de passe des applications)
GMAIL_USER=eliescott227@gmail.com
GMAIL_APP_PASSWORD=dyfi lovp idxy mqqp

# Boîte qui reçoit les messages du portfolio (souvent la même que GMAIL_USER)
CONTACT_TO_EMAIL=eliescott227@gmail.com

# Si Gmail refuse encore la connexion : décommente → GMAIL_SMTP_PORT=587
# Diagnostic : npm run verify-mail

# Front : URL de l’API en production, ex. https://ton-api.com
# En local, laisse vide : Create React App proxy → http://localhost:5001/api/contact
REACT_APP_CONTACT_API_URL=

# Optionnel : Web3Forms / Formspree si tu n’utilises pas Gmail
# REACT_APP_WEB3FORMS_ACCESS_KEY=
# REACT_APP_CONTACT_FORM_URL=